{
  "name": "@scanupload/qr-code-generator",
  "version": "0.1.5",
  "description": "A reusable qr-code-generator library using Tailwind CSS v4, React, and Vite for the ScanUpload SAAS application.",
  "main": "dist/qr-code-generator.cjs.js",
  "module": "dist/qr-code-generator.es.js",
  "style": "dist/index.css",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@microsoft/signalr": "^10.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "lucide-react": "^0.562.0",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "^7.1.11",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-mkcert": "^1.17.8"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": ">=19",
    "react-dom": ">=19",
    "react-icons": "^5.5.0",
    "react-qr-code": "^2.0.18",
    "tailwind-merge": "^3.5.0"
  },
  "keywords": [
    "react",
    "typescript",
    "tailwind-v4",
    "vite",
    "qr-code-generator"
  ],
  "author": "Donald Asante",
  "license": "MIT"
}
